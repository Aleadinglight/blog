---
import type { CollectionEntry } from "astro:content";
import { CalendarDays } from "@lucide/astro";
import { SITE_ROOT } from "../consts";

type Props = {
  post: CollectionEntry<"posts">;
  highlightTag?: string; // Optional tag to highlight (for tag pages)
};

const { post, highlightTag } = Astro.props;
---

<article class="my-0 py-2 px-4 rounded-lg flex flex-col gap-4 border border-transparent w-full">
  <div class="flex-1">
    <h3 class="text-lg font-semibold text-gray-800">
      <a
        href={`${SITE_ROOT}posts/${post.id}`}
        class="hover:underline"
      >
        {post.data.title}
      </a>
    </h3>
    <span class="flex text-gray-600 items-center">
      <CalendarDays size={16} stroke-width={2} />
      <p class="pl-1 text-sm">
        {post.data.pubDate.toLocaleDateString("en-us", {
          year: "numeric",
          month: "long",
          day: "2-digit",
        })}
      </p>
    </span>
    {post.data.description && (
      <p class="text-gray-600">{post.data.description}</p>
    )}
    {post.data.tags?.length ? (
      <p class="text-gray-500 text-sm mt-1">
        {post.data.tags.map((tag) => (
          <a
            href={`${SITE_ROOT}tags/${tag}`}
            class={`inline-flex ml-1 items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset transition-colors ${
              highlightTag && tag === highlightTag
                ? 'bg-blue-100 text-blue-700 ring-blue-200'
                : 'bg-gray-50 text-gray-600 ring-gray-500/10 hover:bg-blue-50 hover:text-blue-700'
            }`}
          >
            {tag}
          </a>
        ))}
      </p>
    ) : null}
  </div>
</article>

