---
import { SITE_ROOT } from "../consts";
import { Rss } from "@lucide/astro";
---

<footer class="py-4 border-t border-gray-200 w-full bg-gray-100 mt-30">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between">
    <p class="text-gray-600 text-xs sm:text-sm font-bold">
      © citizenmammoth
    </p>
    <a
      href={`${SITE_ROOT}rss.xml`}
      title="RSS Feed"
      class="inline-flex items-center gap-1 text-gray-400 hover:text-orange-500 transition-colors text-xs sm:text-sm"
    >
      <Rss size={16} stroke-width={2} />
      RSS
    </a>
  </div>
</footer>
